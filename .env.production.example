NODE_ENV=production
PORT=3001
# Coller connexion "Session pooler" depuis Supabase > Connect.
# Conserver sslmode=require. Ne jamais exposer cette valeur au frontend.
DATABASE_URL=
SUPABASE_PROJECT_REF=hozhnlzgbccrkdluqjcg
SUPABASE_URL=https://hozhnlzgbccrkdluqjcg.supabase.co
TRUST_PROXY=1
FORCE_HTTPS=true
PUBLIC_URL=https://erp.example.com
JWT_SECRET=
DATA_ENCRYPTION_KEY=
ADMIN_PASSWORD=
RESET_ADMIN_PASSWORD_ON_START=false
ALLOWED_ORIGINS=https://erp.example.com
BACKUP_DIR=/app/backups
BACKUP_RETENTION=50
AUDIT_RETENTION_DAYS=365
HTTP_GLOBAL_RATE_LIMIT=60000
TARGET_CONCURRENT_USERS=100
WS_MAX_CONNECTIONS_PER_IP=250
WS_MAX_CONNECTIONS_PER_USER=5
REDIS_URL=redis://redis:6379
REDIS_REQUIRED=true
REDIS_CHANNEL=intelsheets:realtime:v1
METRICS_TOKEN=
METRICS_ALLOW_UNAUTHENTICATED=false
GRAFANA_ADMIN_PASSWORD=
S3_BACKUP_BUCKET=
S3_BACKUP_REGION=
S3_BACKUP_ENDPOINT=
S3_BACKUP_PREFIX=intelsheets
S3_FORCE_PATH_STYLE=false
S3_SERVER_SIDE_ENCRYPTION=AES256
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
PLUGIN_ALLOWLIST=system-insights
GROQ_API_KEY=
SITE_AGENT_MODEL=llama-3.3-70b-versatile
MAIL_SYNC_INTERVAL_MS=60000
